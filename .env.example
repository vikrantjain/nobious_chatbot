IMS_BASE_URL=https://tenant1.nobious.io:5443
IMS_AUTH_URL=https://tenant1.nobious.io:5443

# LLM configuration (generic - change provider/model to switch backends)
LLM_MODEL=claude-haiku-4-5-20251001
LLM_PROVIDER=bedrock_converse

# AWS credentials (required when LLM_PROVIDER=bedrock_converse)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

GITHUB_REPO_URL=
GITHUB_TOKEN=
DOC_INDEX_PATH=./doc_index
MAX_QUERY_LENGTH=200
RATE_LIMIT_PER_MIN=3
